# ─── WatchVault environment ───────────────────────────────────────────────
# Copy to `.env` and adjust. NEVER commit a real .env.

# Ports
WEB_PORT=7210            # public entry point (nginx) — serves the PWA, /api and /mcp
# MCP is reached at  http://<host>:${WEB_PORT}/mcp  (no separate port needed)
API_PORT=7200            # internal backend API (gunicorn) — not exposed publicly
MCP_PORT=7211            # internal MCP server — proxied at /mcp, not exposed publicly

# Persistent data path on the host (survives container rebuilds).
# Both the app data and the PostgreSQL database live under this folder
# (in ./app and ./postgres). Use an absolute path in production so the data
# is not tied to the compose file's location.
# Unraid / NAS example: /mnt/user/appdata/Stack/watchvault-production
DATA_PATH=./data

# Database
POSTGRES_USER=watchvault
POSTGRES_PASSWORD=change-me
POSTGRES_DB=watchvault
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Auth / WebAuthn relying party
RP_ID=localhost
RP_NAME=WatchVault
RP_ORIGINS=http://localhost:7210
SESSION_SECRET=change-me-to-a-long-random-string
SESSION_TTL_HOURS=24

# Bootstrap: the first user to register becomes the household admin.
# Set to a known invite code to gate registration (optional).
REGISTRATION_INVITE_CODE=

# Metadata providers (optional — app runs without these)
TMDB_API_KEY=

# App
APP_ENV=production
LOG_LEVEL=INFO
